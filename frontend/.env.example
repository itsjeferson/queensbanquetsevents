# Copy to .env for local dev (frontend/.env is gitignored)
#
# Use the Render API while doing frontend-only work (recommended):
VITE_API_URL=https://queens-banquet-api.onrender.com
#
# Use this only when running the PHP backend locally (php -S localhost:8000):
# VITE_API_URL=http://localhost:8000
#
VITE_APP_NAME=Queen's Banquet Events
#
# Public site URL used for invitation links and QR codes (no trailing slash).
# Set this on Vercel to your production domain, e.g. https://queensbanquetsevents.vercel.app
VITE_PUBLIC_SITE_URL=https://queensbanquetsevents.vercel.app
