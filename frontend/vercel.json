{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/queens-banquet-events.html", "destination": "/", "permanent": false },
    { "source": "/invite/:slug", "destination": "/#/invite/:slug", "permanent": false },
    { "source": "/invitation/:slug", "destination": "/#/invite/:slug", "permanent": false },
    { "source": "/i/:code", "destination": "/#/i/:code", "permanent": false }
  ]
}
