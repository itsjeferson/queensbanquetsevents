{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/queens-banquet-events.html", "destination": "/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/invite/:slug", "destination": "/index.html" },
    { "source": "/invitation/:slug", "destination": "/index.html" },
    { "source": "/i/:code", "destination": "/index.html" }
  ]
}
